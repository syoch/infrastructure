# Tailscale configuration example
# Copy this file to tailscale/.env and fill in your values

# Tailscale auth key (get from https://login.tailscale.com/admin/settings/keys)
TS_AUTH_KEY=tskey-auth-XXXXXXXXXXXXX-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Hostname for this machine in Tailscale network
TS_HOSTNAME=your-hostname
